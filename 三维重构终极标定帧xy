ax4.set_title('3D点云 (标定帧理论坐标)', fontsize=11, fontweight='bold')
ax4.set_xlabel('X (mm)')
ax4.set_ylabel('Y (mm)')
ax4.set_zlabel('Z (mm)')
ax4.view_init(elev=30, azim=-60)

# 子图5: 高度分布直方图
ax5 = fig.add_subplot(2, 3, 5)
ax5.hist(z_valid, bins=30, color='steelblue', edgecolor='black', alpha=0.85)
ax5.axvline(z_valid.mean(), color='r', linestyle='--', 
           label=f'均值: {z_valid.mean():.4f} mm')
ax5.axvline(z_valid.mean() - z_valid.std(), color='g', linestyle=':', alpha=0.7)
ax5.axvline(z_valid.mean() + z_valid.std(), color='g', linestyle=':', alpha=0.7,
           label=f'±1σ ({z_valid.std():.4f} mm)')
ax5.set_title('高度分布直方图', fontsize=11, fontweight='bold')
ax5.set_xlabel('Height (mm)')
ax5.set_ylabel('Frequency')
ax5.legend(fontsize=9)
ax5.grid(True, alpha=0.3)

# 子图6: 匹配质量分析
ax6 = fig.add_subplot(2, 3, 6)
if num_matched > 0:
    matched_dists = match_distances[matches >= 0]
    ax6.hist(matched_dists, bins=20, color='coral', edgecolor='black', alpha=0.8)
    ax6.axvline(np.mean(matched_dists), color='r', linestyle='--',
               label=f'平均Y偏移: {np.mean(matched_dists):.2f}px')
    ax6.set_title('匹配Y方向偏移分布', fontsize=11, fontweight='bold')
    ax6.set_xlabel('Y方向偏移量 (像素)')
    ax6.set_ylabel('Frequency')
    ax6.legend(fontsize=9)
    ax6.grid(True, alpha=0.3)
else:
    ax6.text(0.5, 0.5, '无匹配光斑', ha='center', va='center', 
            fontsize=14, color='red', fontweight='bold')
    ax6.set_title('匹配质量分析', fontsize=11, fontweight='bold')

plt.tight_layout()
plt.suptitle('光谱共焦三维重构 - 标定帧理论坐标版', 
            fontsize=14, fontweight='bold', y=0.995)
plt.show()

# 8. 保存结果
if save_results:
    output_dir = os.path.dirname(sample_img_path)
    base_name = os.path.splitext(os.path.basename(sample_img_path))[0]
    
