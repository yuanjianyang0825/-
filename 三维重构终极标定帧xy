ax2.set_title(f'光斑匹配结果', fontsize=11, fontweight='bold')
ax2.legend(loc='upper right', fontsize=8)
ax2.axis('off')

# 子图3: 高度热力图（✅ 使用标定帧理论坐标）
ax3 = fig.add_subplot(2, 3, 3)
sc = ax3.scatter(x_calib_matched, H - y_calib_matched, c=z_valid, cmap='jet', s=30, 
                edgecolors='k', linewidth=0.3, alpha=0.8)
ax3.set_title('高度热力图 (标定帧理论坐标)', fontsize=11, fontweight='bold')
ax3.set_xlabel('X (像素)')
ax3.set_ylabel('Y (像素)')
